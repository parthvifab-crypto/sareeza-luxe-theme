<section class="section-padding">
  <div class="page-width">
    <div class="section-heading">
      <h1 class="section-title">{{ section.settings.heading }}</h1>
      <p class="section-subtitle">Explore all Sareeza Luxe collections.</p>
    </div>

    <div class="grid grid--4">
      {% for collection in collections %}
        <article class="card">
          <a href="{{ collection.url }}" class="product-card__media">
            {% if collection.image != blank %}
              {{ collection.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: collection.title }}
            {% elsif collection.products.first.featured_image != blank %}
              {{ collection.products.first.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: collection.title }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </a>
          <div class="product-card__info">
            <h2 class="product-card__title"><a href="{{ collection.url }}">{{ collection.title }}</a></h2>
            <p>{{ collection.products_count }} products</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All collections"
    }
  ]
}
{% endschema %}
