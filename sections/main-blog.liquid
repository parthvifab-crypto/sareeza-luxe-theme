<section class="section-padding">
  <div class="page-width">
    <h1 class="section-title">{{ blog.title }}</h1>
    {% paginate blog.articles by 12 %}
      <div class="grid grid--3">
        {% for article in blog.articles %}
          <article class="card">
            {% if article.image != blank %}
              <a href="{{ article.url }}" class="product-card__media">
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title }}
              </a>
            {% endif %}
            <div class="product-card__info">
              <h2 class="product-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
              <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <nav style="margin-top:32px;text-align:center;">{{ paginate | default_pagination }}</nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
