<header class="site-header">
  <div class="lf-header-mobile">
    <button class="lf-icon" type="button" aria-label="Menu">☰</button>
    <a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name }}">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 180 | image_tag: loading: 'eager', alt: shop.name }}
      {% else %}
        {{ shop.name }}
      {% endif %}
    </a>
    <div class="lf-icon-row">
      <a class="lf-icon" href="{{ routes.search_url }}" aria-label="Search">⌕</a>
      <a class="lf-icon" href="{{ routes.account_url }}" aria-label="Account">♡</a>
      <a class="lf-icon" href="{{ routes.cart_url }}" aria-label="Cart">🛒<span>{{ cart.item_count }}</span></a>
    </div>
  </div>

  <div class="page-width site-header__inner">
    <a href="{{ routes.root_url }}" class="site-logo site-logo--desktop" aria-label="{{ shop.name }}">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 220 | image_tag: loading: 'eager', alt: shop.name }}
      {% else %}
        {{ shop.name }}
      {% endif %}
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="site-actions">
      <a href="{{ routes.search_url }}">Search</a>
      <a href="{{ routes.account_url }}">Account</a>
      <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
    </div>
  </div>

  <nav class="lf-bottom-nav" aria-label="Mobile bottom navigation">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="{{ routes.search_url }}">Search</a>
    <a href="{{ routes.cart_url }}">Cart</a>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
