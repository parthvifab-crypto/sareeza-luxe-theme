<section class="section-padding">
  <div class="page-width">
    <div class="section-heading">
      <h1 class="section-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="section-subtitle rte">{{ collection.description }}</div>
      {% endif %}
    </div>

    <div class="collection-toolbar">
      <span>{{ collection.products_count }} products</span>
    </div>

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="grid grid--4">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% else %}
          <div class="empty-state">
            <h3>No products found</h3>
            <p>Add products to this collection from Shopify admin.</p>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="pagination" style="margin-top:32px;text-align:center;">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
