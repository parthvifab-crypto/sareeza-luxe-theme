<section class="hero">
  <div class="page-width hero__content">
    <p class="hero__eyebrow">{{ shop.name }}</p>
    <h1 class="hero__title">Opening soon</h1>
    <p class="hero__text">Our premium ethnic fashion store is getting ready.</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="Password" style="padding:14px 18px;border:1px solid #ead8de;border-radius:999px;min-width:260px;">
      <button type="submit" class="btn">Enter</button>
      {{ form.errors | default_errors }}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Main password",
  "settings": []
}
{% endschema %}
