<section class="section-padding">
  <div class="page-width">
    <div class="section-heading">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.text }}</p>
    </div>

    <div class="grid grid--4">
      {% for block in section.blocks %}
        <a class="category-card" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {% endif %}
          <span class="category-card__title">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by category",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Browse curated ethnic styles for every occasion."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Sarees"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by category",
      "blocks": [
        { "type": "category", "settings": { "title": "Sarees" } },
        { "type": "category", "settings": { "title": "Kurtis" } },
        { "type": "category", "settings": { "title": "Kurta Sets" } },
        { "type": "category", "settings": { "title": "Festive Wear" } }
      ]
    }
  ]
}
{% endschema %}
