<section class="hero">
  <div class="page-width hero__content">
    {% if section.settings.eyebrow != blank %}
      <div class="hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h1 class="hero__title">{{ section.settings.heading }}</h1>
    <p class="hero__text">{{ section.settings.text }}</p>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sareeza Luxe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury Ethnic Wear for Every Occasion"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Discover premium sarees, kurtis and festive fashion crafted for modern Indian women."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
