<section class="section-padding">
  <div class="page-width">
    <div class="newsletter">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.text }}</p>

      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Enter your email" required>
        <button type="submit" class="btn">{{ section.settings.button_label }}</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join Sareeza Luxe"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Get updates on new ethnic collections, festive drops and styling inspiration."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
