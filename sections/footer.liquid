<footer class="footer">
  <div class="page-width footer__grid">
    <div class="footer__block">
      <h3>CONTACT WITH US</h3>
      <p>{{ section.settings.contact_text }}</p>
    </div>

    <div class="footer__block">
      <h3>MENU</h3>
      {% if section.settings.menu_1 != blank %}
        {% for link in section.settings.menu_1.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ routes.all_products_collection_url }}">Catalog</a>
        <a href="{{ routes.search_url }}">Search</a>
      {% endif %}
    </div>

    <div class="footer__block">
      <h3>INFORMATION</h3>
      {% if section.settings.menu_2 != blank %}
        {% for link in section.settings.menu_2.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/pages/about-us">About Us</a>
        <a href="/pages/contact">Contact Us</a>
        <a href="/pages/track-order">Track Order</a>
      {% endif %}
    </div>

    <div class="footer__block">
      <h3>NEWSLETTER SIGNUP</h3>
      <p>{{ section.settings.about }}</p>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Email address" required>
        <button type="submit">Subscribe</button>
      {% endform %}
    </div>
  </div>

  <div class="page-width footer__payment">
    <span>💳 Visa</span>
    <span>💳 Mastercard</span>
    <span>💳 UPI</span>
    <span>💳 Paytm</span>
    <span>💳 COD</span>
  </div>

  <div class="page-width footer__bottom">
    © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about",
      "label": "Newsletter text",
      "default": "Subscribe for new launches, sale updates and fashion drops."
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu links"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Information links"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Contact text",
      "default": "Customer support available for orders, shipping and returns."
    }
  ]
}
{% endschema %}
